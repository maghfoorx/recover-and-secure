shamefully-hoist=true
# Skip pnpm's pre-run "verify deps" install check. Running `pnpm convex
# deploy` otherwise triggers an internal `pnpm install` that hard-fails on
# ERR_PNPM_IGNORED_BUILDS (electron/esbuild/sqlite3 build scripts), which
# blocks the deploy even though those native builds are irrelevant to it.
verify-deps-before-run=false
