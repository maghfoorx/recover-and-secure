# Frontend runtime
# Use 127.0.0.1 when the Electron app and Docker containers run on the same machine.
# In the real offline deployment, replace this with the mini PC's LAN IP.
VITE_CONVEX_URL=http://127.0.0.1:3210

# Optional Convex self-hosted admin/CLI settings.
# Generate an admin key with:
# docker compose exec backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-with-generated-admin-key

# Optional Docker Compose port overrides.
PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791
